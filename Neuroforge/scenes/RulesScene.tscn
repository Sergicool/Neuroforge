theme_override_constants/outline_size = 6
theme_override_font_sizes/normal_font_size = 20
text = "Important to know:

- The game is turn-based. You can only perform one action per turn, attack or move.

- The identities of your pieces will be unknown to the enemy, just as you will not know theirs. Their identities will be revealed once they enter in combat."
fit_content = true

