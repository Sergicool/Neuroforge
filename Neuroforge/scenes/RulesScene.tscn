text = "A combat begins when you move your piece to a tile occupied by the enemy, and vice versa. Both identities are revealed."
fit_content = true

[node name="RichTextLabel3" type="RichTextLabel" parent="TabContainer/Tab4" unique_id=1235044733]
layout_mode = 1
