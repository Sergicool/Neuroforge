theme_override_constants/outline_size = 6
theme_override_font_sizes/normal_font_size = 20
text = "Commander, you have an army of 40 units. Your main objective is to destroy the enemy Energy Core or leave him without any possible movements."
fit_content = true

[node name="RichTextLabel2" type="RichTextLabel" parent="TabContainer/Tab1" unique_id=1220908717]
