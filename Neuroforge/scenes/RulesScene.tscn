offset_right = -346.0
offset_bottom = 77.0
grow_horizontal = 2
size_flags_vertical = 0
theme_override_constants/outline_size = 6
theme_override_font_sizes/normal_font_size = 20
text = "As a general rule, pieces move one square orthogonally (up, down, left, right). There is no diagonal movement."
fit_content = true

[node name="RichTextLabel3" type="RichTextLabel" parent="TabContainer/Tab3" unique_id=1229443189]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_left = 19.0
offset_top = 121.0
offset_right = -376.0
offset_bottom = 209.0
grow_horizontal = 2
size_flags_vertical = 0
theme_override_constants/outline_size = 6
theme_override_font_sizes/normal_font_size = 20
text = "Your recognition unit (The SCOUT) can move any distance in a straight line, but if it advances more than one square, your opponent might be able to deduce what type of piece it is."
fit_content = true

[node name="RichTextLabel4" type="RichTextLabel" parent="TabContainer/Tab3" unique_id=1389558388]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_left = 19.0
offset_top = 288.0
offset_right = -376.0
offset_bottom = 442.0
grow_horizontal = 2
size_flags_vertical = 0
theme_override_constants/outline_size = 6
theme_override_font_sizes/normal_font_size = 20
text = "Restrictions:

- You cannot jump over pieces (your own or your opponent's). Carefull with this rule, you can stuck a piece for the next turn.

- A piece cannot return to a square it has just left until after 3 turns."
fit_content = true

