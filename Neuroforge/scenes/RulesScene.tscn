size_flags_vertical = 0
theme_override_constants/outline_size = 6
theme_override_font_sizes/normal_font_size = 20
text = "A combat is decided in the following way:

- The Higher Rank piece defeats the Lower Rank piece.
- If the ranks are equal, ends in a draw and both pieces are destroyed.
- In case of a special interaction, the other conditions will be ignored.

The winner keeps the tile. If the attacker wins, they advance, and if the defender wins, they stay in their place."
fit_content = true

